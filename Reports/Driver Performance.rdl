  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=.;Initial Catalog=s</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>d9979b13-ceab-4449-8d9b-c38f785985fd</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT
    d.first_name + ' ' + d.last_name  AS DriverName,
    SUM(m.trips_completed)            AS TripsCompleted,
    AVG(m.on_time_delivery_rate)*100  AS AvgOnTimeRate,
    SUM(m.total_revenue)              AS TotalRevenue
FROM dwh.Fact_DriverMonthlyMetrics m
JOIN dwh.Dim_Drivers d ON m.driver_key = d.driver_key
GROUP BY d.driver_key, d.first_name, d.last_name
ORDER BY TripsCompleted DESC </CommandText>
      </Query>
      <Fields>
        <Field Name="DriverName">
          <DataField>DriverName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TripsCompleted">
          <DataField>TripsCompleted</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="AvgOnTimeRate">
          <DataField>AvgOnTimeRate</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TotalRevenue">
          <DataField>TotalRevenue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
